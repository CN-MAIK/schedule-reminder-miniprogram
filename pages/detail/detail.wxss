/* 日程详情页样式 */

.container {
  padding: 32rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 信息卡 */
.info-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #fff;
}

.check-circle.checked {
  background-color: #07c160;
  border-color: #07c160;
}

.info-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
}

.title-completed {
  text-decoration: line-through;
  color: #999;
}

/* 元信息 */
.info-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f8f8f8;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.meta-icon {
  font-size: 28rpx;
}

/* 详情 */
.detail-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.detail-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.edit-btn {
  background-color: #07c160;
  color: #ffffff;
}

.edit-btn:active {
  opacity: 0.85;
}

.delete-btn {
  background-color: #ffffff;
  color: #ee0a24;
  border: 2rpx solid #ee0a24;
}

.delete-btn:active {
  background-color: #fff5f5;
}