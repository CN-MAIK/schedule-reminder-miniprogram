<view class="container">
  <view class="header">
    <text class="title">添加日程</text>
  </view>

  <view class="form">
    <!-- 日程标题 -->
    <view class="form-item">
      <text class="label">日程标题</text>
      <input
        class="input"
        placeholder="请输入日程标题"
        value="{{title}}"
        bindinput="onTitleInput"
      />
    </view>

    <!-- 日期选择 -->
    <view class="form-item">
      <text class="label">日期</text>
      <picker
        mode="date"
        value="{{date}}"
        start="{{today}}"
        bindchange="onDateChange"
      >
        <view class="picker-display">
          <text class="{{date ? 'picker-text' : 'picker-placeholder'}}">
            {{date || '请选择日期'}}
          </text>
          <text class="picker-arrow">▸</text>
        </view>
      </picker>
    </view>

    <!-- 日程详情 -->
    <view class="form-item">
      <text class="label">详情</text>
      <textarea
        class="textarea"
        placeholder="请输入日程详情（可选）"
        value="{{detail}}"
        bindinput="onDetailInput"
        maxlength="500"
        auto-height
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="onSave" disabled="{{!canSave}}">
    保存
  </button>
</view>
