/* 添加/编辑日程页面样式 */

.container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 48rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* 表单区域 */
.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

/* 输入框 */
.input {
  font-size: 32rpx;
  color: #1a1a1a;
  height: 56rpx;
  line-height: 56rpx;
}

/* 选择器 */
.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 56rpx;
  line-height: 56rpx;
}

.picker-text {
  font-size: 32rpx;
  color: #1a1a1a;
}

.picker-placeholder {
  font-size: 32rpx;
  color: #ccc;
}

.picker-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 开关行 */
.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-item .label {
  margin-bottom: 0;
}

/* 多行文本 */
.textarea {
  font-size: 30rpx;
  color: #1a1a1a;
  width: 100%;
  min-height: 160rpx;
  line-height: 1.6;
}

/* 保存按钮 */
.save-btn {
  margin-top: 64rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
}

.save-btn[disabled] {
  background-color: #9ed8b3;
  color: #ffffff;
}

.save-btn:not([disabled]):active {
  opacity: 0.85;
}