<view class="container">
  <!-- 顶部栏 -->
  <view class="header">
    <text class="header-title">我的日程</text>
    <view class="header-right" bindtap="onToggleView">
      <text class="view-toggle">{{showCalendar ? '全部 ▾' : '日历 ▴'}}</text>
    </view>
  </view>

  <!-- 万年历区域 -->
  <view class="calendar-section" wx:if="{{showCalendar}}">
    <!-- 月份切换 -->
    <view class="calendar-header">
      <view class="arrow-btn" bindtap="onPrevMonth">
        <text class="arrow">◂</text>
      </view>
      <text class="month-title">{{calendarTitle}}</text>
      <view class="arrow-btn" bindtap="onNextMonth">
        <text class="arrow">▸</text>
      </view>
    </view>

    <!-- 星期标题 -->
    <view class="weekdays">
      <text class="weekday" wx:for="{{weekLabels}}" wx:key="*this">{{item}}</text>
    </view>

    <!-- 日期网格 -->
    <view class="days-grid">
      <view
        class="day-cell {{item.isOtherMonth ? 'other-month' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        wx:for="{{calendarDays}}"
        wx:key="key"
        bindtap="onDayTap"
        data-date="{{item.date}}"
        data-is-other="{{item.isOtherMonth}}"
      >
        <text class="day-num">{{item.day}}</text>
        <view class="day-dot" wx:if="{{item.hasSchedule}}"></view>
      </view>
    </view>
  </view>

  <!-- 选中日期信息栏（日历模式下显示） -->
  <view class="date-info-bar" wx:if="{{showCalendar}}">
    <text class="date-info-text">{{selectedDateInfo}}</text>
    <text class="date-info-count" wx:if="{{filteredList.length}}">{{filteredList.length}} 项日程</text>
    <text class="date-info-count" wx:else>暂无日程</text>
  </view>

  <!-- 筛选标签（非日历模式下显示） -->
  <view class="filter-bar" wx:if="{{!showCalendar && schedules.length}}">
    <view class="filter-tab {{filter === 'all' ? 'active' : ''}}" bindtap="onFilter" data-filter="all">全部</view>
    <view class="filter-tab {{filter === 'pending' ? 'active' : ''}}" bindtap="onFilter" data-filter="pending">待办</view>
    <view class="filter-tab {{filter === 'completed' ? 'active' : ''}}" bindtap="onFilter" data-filter="completed">已完成</view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!filteredList.length}}">
    <text class="empty-icon">📅</text>
    <text class="empty-text">{{showCalendar ? selectedDate + ' 暂无日程' : '还没有日程'}}</text>
    <text class="empty-hint">点击右下角按钮添加</text>
  </view>

  <!-- 日程列表 -->
  <view class="list" wx:if="{{filteredList.length}}">
    <view class="card {{item.completed ? 'card-completed' : ''}}" wx:for="{{filteredList}}" wx:key="id" bindtap="onItemTap" data-index="{{index}}">
      <view class="card-top">
        <view class="card-title-row">
          <!-- 完成勾选 -->
          <view class="check-circle {{item.completed ? 'checked' : ''}}" catchtap="onToggleComplete" data-id="{{item.id}}">
            <text wx:if="{{item.completed}}">✓</text>
          </view>
          <text class="card-title {{item.completed ? 'title-completed' : ''}}">{{item.title}}</text>
        </view>
        <view class="card-meta">
          <text class="card-date" wx:if="{{!showCalendar}}">{{item.date}}</text>
          <text class="card-time" wx:if="{{item.time}}">{{item.time}}</text>
          <text class="card-remind" wx:if="{{item.remind}}">🔔</text>
        </view>
      </view>
      <text class="card-detail" wx:if="{{item.detail}}">{{item.detail}}</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab" bindtap="onAdd">
    <text class="fab-icon">+</text>
  </view>
</view>
